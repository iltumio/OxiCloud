{
  "openapi": "3.1.0",
  "info": {
    "title": "oxicloud",
    "description": "",
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
  "paths": {
    "/folders": {
      "get": {
        "tags": [
          "folders"
        ],
        "summary": "Lists root folders",
        "operationId": "list_root_folders",
        "responses": {
          "200": {
            "description": "List of root folders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FolderDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "folders"
        ],
        "summary": "Creates a new folder",
        "operationId": "create_folder",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateFolderDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Folder created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FolderDto"
                }
              }
            }
          },
          "404": {
            "description": "Parent folder not found"
          },
          "409": {
            "description": "Folder already exists"
          }
        }
      }
    },
    "/folders/paginated": {
      "get": {
        "tags": [
          "folders"
        ],
        "summary": "Lists root folders with pagination",
        "operationId": "list_root_folders_paginated",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Página solicitada (comienza en 0)",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "Tamaño de página solicitado",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of root folders",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponseDto_FolderDto"
                }
              }
            }
          }
        }
      }
    },
    "/folders/{id}": {
      "get": {
        "tags": [
          "folders"
        ],
        "summary": "Gets a folder by ID",
        "operationId": "get_folder",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Folder ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Folder details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FolderDto"
                }
              }
            }
          },
          "404": {
            "description": "Folder not found"
          }
        }
      },
      "delete": {
        "tags": [
          "folders"
        ],
        "summary": "Deletes a folder with trash functionality",
        "operationId": "delete_folder_with_trash",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Folder ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Folder deleted"
          },
          "404": {
            "description": "Folder not found"
          }
        }
      }
    },
    "/folders/{id}/contents": {
      "get": {
        "tags": [
          "folders"
        ],
        "summary": "Lists folder contents",
        "operationId": "list_folder_contents",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Folder ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of folder contents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FolderDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/folders/{id}/contents/paginated": {
      "get": {
        "tags": [
          "folders"
        ],
        "summary": "Lists folder contents with pagination",
        "operationId": "list_folder_contents_paginated",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Folder ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Página solicitada (comienza en 0)",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "Tamaño de página solicitado",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of folder contents",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponseDto_FolderDto"
                }
              }
            }
          }
        }
      }
    },
    "/folders/{id}/move": {
      "put": {
        "tags": [
          "folders"
        ],
        "summary": "Moves a folder to a new parent",
        "operationId": "move_folder",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Folder ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MoveFolderDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Folder moved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FolderDto"
                }
              }
            }
          },
          "404": {
            "description": "Folder not found"
          },
          "409": {
            "description": "Destination conflict"
          }
        }
      }
    },
    "/folders/{id}/rename": {
      "put": {
        "tags": [
          "folders"
        ],
        "summary": "Renames a folder",
        "operationId": "rename_folder",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Folder ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RenameFolderDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Folder renamed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FolderDto"
                }
              }
            }
          },
          "404": {
            "description": "Folder not found"
          },
          "409": {
            "description": "Folder name already exists"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateFolderDto": {
        "type": "object",
        "description": "DTO for folder creation requests",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the folder to create"
          },
          "parent_id": {
            "type": [
              "string",
              "null"
            ],
            "description": "Parent folder ID (None for root level)"
          }
        }
      },
      "FolderDto": {
        "type": "object",
        "description": "DTO for folder responses",
        "required": [
          "id",
          "name",
          "path",
          "created_at",
          "modified_at",
          "is_root"
        ],
        "properties": {
          "created_at": {
            "type": "integer",
            "format": "int64",
            "description": "Creation timestamp",
            "minimum": 0
          },
          "id": {
            "type": "string",
            "description": "Folder ID"
          },
          "is_root": {
            "type": "boolean",
            "description": "Whether this is a root folder"
          },
          "modified_at": {
            "type": "integer",
            "format": "int64",
            "description": "Last modification timestamp",
            "minimum": 0
          },
          "name": {
            "type": "string",
            "description": "Folder name"
          },
          "parent_id": {
            "type": [
              "string",
              "null"
            ],
            "description": "Parent folder ID"
          },
          "path": {
            "type": "string",
            "description": "Path to the folder (relative)"
          }
        }
      },
      "MoveFolderDto": {
        "type": "object",
        "description": "DTO for folder move requests",
        "properties": {
          "parent_id": {
            "type": [
              "string",
              "null"
            ],
            "description": "New parent folder ID (None for root level)"
          }
        }
      },
      "PaginatedResponseDto_FolderDto": {
        "type": "object",
        "description": "Un DTO para representar una respuesta paginada",
        "required": [
          "items",
          "pagination"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "description": "DTO for folder responses",
              "required": [
                "id",
                "name",
                "path",
                "created_at",
                "modified_at",
                "is_root"
              ],
              "properties": {
                "created_at": {
                  "type": "integer",
                  "format": "int64",
                  "description": "Creation timestamp",
                  "minimum": 0
                },
                "id": {
                  "type": "string",
                  "description": "Folder ID"
                },
                "is_root": {
                  "type": "boolean",
                  "description": "Whether this is a root folder"
                },
                "modified_at": {
                  "type": "integer",
                  "format": "int64",
                  "description": "Last modification timestamp",
                  "minimum": 0
                },
                "name": {
                  "type": "string",
                  "description": "Folder name"
                },
                "parent_id": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "Parent folder ID"
                },
                "path": {
                  "type": "string",
                  "description": "Path to the folder (relative)"
                }
              }
            },
            "description": "Datos en la página actual"
          },
          "pagination": {
            "$ref": "#/components/schemas/PaginationDto",
            "description": "Información de paginación"
          }
        }
      },
      "PaginationDto": {
        "type": "object",
        "description": "Un DTO para representar información de paginación",
        "required": [
          "page",
          "page_size",
          "total_items",
          "total_pages",
          "has_next",
          "has_prev"
        ],
        "properties": {
          "has_next": {
            "type": "boolean",
            "description": "Indica si hay una página siguiente"
          },
          "has_prev": {
            "type": "boolean",
            "description": "Indica si hay una página anterior"
          },
          "page": {
            "type": "integer",
            "description": "Página actual (comienza en 0)",
            "minimum": 0
          },
          "page_size": {
            "type": "integer",
            "description": "Tamaño de página",
            "minimum": 0
          },
          "total_items": {
            "type": "integer",
            "description": "Número total de elementos",
            "minimum": 0
          },
          "total_pages": {
            "type": "integer",
            "description": "Número total de páginas",
            "minimum": 0
          }
        }
      },
      "PaginationRequestDto": {
        "type": "object",
        "description": "Un DTO para representar una solicitud de paginación",
        "properties": {
          "page": {
            "type": "integer",
            "description": "Página solicitada (comienza en 0)",
            "minimum": 0
          },
          "page_size": {
            "type": "integer",
            "description": "Tamaño de página solicitado",
            "minimum": 0
          }
        }
      },
      "RenameFolderDto": {
        "type": "object",
        "description": "DTO for folder rename requests",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "New name for the folder"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "folders",
      "description": "Folder management endpoints"
    }
  ]
}